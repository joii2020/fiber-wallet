# Nginx reverse proxy configuration: proxy ws:// to wss://
# Listen on port 443, proxy to backend WebSocket service on port 8248

pid deploy/native-node/nginx.pid;

# Required events block
events {
    worker_connections 1024;
}

# http block contains server configuration
http {
    # Temporary file directories (avoid using system directories)
    client_body_temp_path deploy/native-node/temp/client_body;
    proxy_temp_path deploy/native-node/temp/proxy;
    fastcgi_temp_path deploy/native-node/temp/fastcgi;
    uwsgi_temp_path deploy/native-node/temp/uwsgi;
    scgi_temp_path deploy/native-node/temp/scgi;

    # Log configuration
    access_log deploy/native-node/access.log;
    error_log deploy/native-node/error.log;

    # HTTPS + WebSocket proxy
    server {
        listen 8249 ssl;
        server_name localhost;

        # SSL certificate configuration (self-signed certificate, relative path)
        ssl_certificate ssl/nginx.crt;
        ssl_certificate_key ssl/nginx.key;

        # SSL security configuration
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;
        ssl_prefer_server_ciphers on;

        # WebSocket test page
        location /test_page/ {
            default_type text/html;
            return 200 '<html><body>Hello World</body></html>';
        }

        # WebSocket proxy configuration
        location / {
            proxy_pass http://127.0.0.1:8248;
            
            # WebSocket support
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            
            # Proxy header settings
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            
            # Timeout settings (required for WebSocket long connections)
            proxy_read_timeout 86400;
            proxy_send_timeout 86400;
        }
    }
}
